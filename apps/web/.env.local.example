# ─── Required for Dashboard (Instagram OAuth) ─────────────────────────────────
NEXT_PUBLIC_APP_URL=https://wegoviral.vercel.app
FB_APP_ID=your_facebook_app_id
FB_APP_SECRET=your_facebook_app_secret

# 32+ character random string — generate with: openssl rand -hex 32
SESSION_SECRET=replace-with-a-random-32-character-string

# ─── Required for AI Analysis ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── Express backend URL (for /analyze feature) ───────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
